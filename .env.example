# Copy this file to `.env` in the repository root and fill in your key.
# Never commit `.env` (it is gitignored).

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Per rule: up to 5 each (assignment); lower LLM_FACTS_PER_RULE to reduce API cost while iterating.
LLM_NATURAL_LANGUAGE_EXAMPLES_PER_RULE=5
LLM_FACTS_PER_RULE=5
# Dashboard only: show frozen sample tables/graph from src/brunoOutput (no OpenAI needed to view UI).
# LEIBNIZ_USE_BRUNO_OUTPUT=1
